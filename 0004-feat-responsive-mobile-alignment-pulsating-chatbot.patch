 app/page.tsx           | 12 ++++++------
 app/pricing/page.tsx   |  6 +++---
 components/Chatbot.tsx | 17 ++++++++++++-----
 components/Footer.tsx  |  2 +-
 components/Navbar.tsx  |  4 ++--
 6 files changed, 54 insertions(+), 17 deletions(-)

diff --git a/app/globals.css b/app/globals.css
index ecf824d..d4e467d 100644
--- a/app/globals.css
+++ b/app/globals.css
@@ -350,3 +350,33 @@ button:active, a:active {
 /* AWS-pattern header utility bar */
 .utility-bar a { color: rgba(255, 255, 255, 0.85); }
 .utility-bar a:hover { color: #ffffff; }
+
+/* ---------------------------------------------------------------------------
+   Chat launcher — soothing professional pulse (Intercom-style)
+   --------------------------------------------------------------------------- */
+.chat-launcher-ring {
+  animation: chatRing 3.2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
+  pointer-events: none;
+}
+.chat-launcher-ring-delayed {
+  animation-delay: 1.6s;
+}
+@keyframes chatRing {
+  0%   { transform: scale(1);    opacity: 0.35; }
+  70%  { transform: scale(1.65); opacity: 0; }
+  100% { transform: scale(1.65); opacity: 0; }
+}
+
+.chat-launcher-breathe {
+  animation: chatBreathe 3.2s ease-in-out infinite;
+}
+@keyframes chatBreathe {
+  0%, 100% { transform: scale(1); }
+  50%      { transform: scale(1.045); }
+}
+
+@media (prefers-reduced-motion: reduce) {
+  .chat-launcher-ring,
+  .chat-launcher-breathe { animation: none; }
+  .chat-launcher-ring { display: none; }
+}
