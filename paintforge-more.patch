+          </div>
+          <div style={{ display: "flex", gap: 10 }}>
+            <span style={{ color: "#FF6B35", fontWeight: 700 }}>0</span>
+            <span>capex · RaaS</span>
+          </div>
+        </div>
+      </div>
+    ),
+    { ...OG_SIZE }
+  );
+}
