+
+        <div style={{ display: "flex", flexDirection: "column", gap: 20 }}>
+          <div
+            style={{
+              color: "#FF6B35",
+              fontSize: 22,
+              fontWeight: 600,
+              letterSpacing: 4,
+              textTransform: "uppercase",
+            }}
+          >
+            In development · GTA pilot program · 2026
+          </div>
+          <div
