From 3988eaecdda628eebafa5af9edcf36b8ddff7fe5 Mon Sep 17 00:00:00 2001
From: Vincenzo Grimaldi <vince.ceccarelli@gmail.com>
Date: Sun, 5 Jul 2026 00:56:22 +0000
Subject: [PATCH] feat(ux): smart hide/show header, overlay mobile menu,
 AWS-grade hover system

Header:
- Now fixed with scroll intelligence: hides when scrolling down,
  reappears instantly on any scroll up, always visible near the top
  (6px hysteresis so it never flickers)
- Layout-stable spacer div: switching from sticky to fixed causes zero
  content jump

Mobile menu:
- Converted from inline expander (which pushed the whole page down --
  the bug in the screenshot) to a full-screen overlay below the header
- Body scroll locked while open, closes on Escape, entrance animation,
  contact shortcut added at the bottom

Interaction system (AWS-style 'alive' feel):
- Nav links: accent underline slides in from the left on hover
- Dropdown opens with a soft translate+fade; chevron rotates
- Dropdown/mobile menu items: background sweep + indent on hover
- Cards: accent border joins the existing lift on hover
- Footer links: offset underline fade-in; social icons keep scale, no
  underline artifact
- Smooth in-page scrolling + scroll-margin so anchored sections land
  below the fixed header, not underneath it
- Every new animation disabled under prefers-reduced-motion
---
 app/globals.css       |  66 ++++++++++
 components/Navbar.tsx | 287 ++++++++++++++++++++++++++----------------
 2 files changed, 242 insertions(+), 111 deletions(-)

diff --git a/app/globals.css b/app/globals.css
index d4e467d..04a92c9 100644
--- a/app/globals.css
+++ b/app/globals.css
@@ -380,3 +380,69 @@ button:active, a:active {
   .chat-launcher-breathe { animation: none; }
   .chat-launcher-ring { display: none; }
 }
+
+/* ---------------------------------------------------------------------------
+   AWS-grade "alive" interaction system
+   --------------------------------------------------------------------------- */
+
+/* Smooth in-page scrolling (anchors, Back to top) */
+html { scroll-behavior: smooth; }
+@media (prefers-reduced-motion: reduce) {
+  html { scroll-behavior: auto; }
+}
+
+/* Nav links: animated accent underline sliding in from the left */
+.nav-link { position: relative; }
+.nav-link::after {
+  content: "";
+  position: absolute;
+  left: 0;
+  right: 0;
+  bottom: 0;
+  height: 2px;
+  background: var(--accent);
+  border-radius: 2px;
+  transform: scaleX(0);
+  transform-origin: left;
+  transition: transform 0.22s cubic-bezier(0.4, 0, 0.2, 1);
+}
+.nav-link:hover::after { transform: scaleX(1); }
+
+/* Dropdown & mobile menu items: background sweep + indent on hover */
+.menu-item {
+  transition: background-color 0.15s ease, padding-left 0.15s ease;
+}
+.menu-item:hover {
+  background-color: #f8fafc;
+  padding-left: 1.5rem;
+}
+
+/* Cards: existing lift, plus a live accent border on hover */
+.card:hover { border-color: rgba(255, 107, 53, 0.45); }
+
+/* Footer links: AWS-style underline with breathing room */
+footer a {
+  text-underline-offset: 4px;
+  text-decoration-color: transparent;
+  transition: color 0.15s ease, text-decoration-color 0.15s ease;
+}
+footer a:hover {
+  text-decoration: underline;
+  text-decoration-color: rgba(255, 255, 255, 0.6);
+}
+
+/* Mobile menu entrance */
+@keyframes menuIn {
+  from { opacity: 0; transform: translateY(-8px); }
+  to   { opacity: 1; transform: translateY(0); }
+}
+.animate-menu-in { animation: menuIn 0.18s ease-out both; }
+@media (prefers-reduced-motion: reduce) {
+  .animate-menu-in { animation: none; }
+}
+
+/* Anchored sections stop below the fixed header instead of underneath it */
+[id] { scroll-margin-top: 112px; }
+
+/* Icon-only links (socials) keep their scale effect, never an underline */
+footer a[aria-label]:hover { text-decoration: none; }
