+            <div className="kicker mb-3">AUTONOMOUS PAINTING SYSTEMS</div>
+            <h2 className="section-heading">
+              One platform, working
+              <br />
+              independently on every surface.
+            </h2>
+          </div>
+          <div className="hidden shrink-0 gap-2 sm:flex">
