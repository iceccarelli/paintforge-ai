+"use client";
+
+import React, { useCallback, useEffect, useMemo, useState } from "react";
+import Image from "next/image";
+import { X, ChevronLeft, ChevronRight } from "lucide-react";
+import {
+  SYSTEM_IMAGES,
+  CATEGORY_META,
+  CATEGORY_ORDER,
+  LINE_META,
+  type SystemImage,
+  type SystemLine,
+  type SystemCategory,
+} from "@/lib/systemsCatalog";
+
+// ---------------------------------------------------------------------------
+// SYSTEMS GALLERY — the full deduplicated 80-image library.
+//
+// Every unique render is exposed here, grouped by PRODUCT LINE (FieldForge /
+// StudioForge) and filterable by CATEGORY. Each tile carries a Ken Burns
+// motion loop (reusing the .kb / .kb-0..3 keyframes already in globals.css)
+// and its own caption. Clicking any tile opens the shared lightbox with
+// full image, line, category, and caption, plus keyboard navigation.
+// ---------------------------------------------------------------------------
+
+type LineFilter = SystemLine | "ALL";
+type CatFilter = SystemCategory | "ALL";
+
+const LINES: SystemLine[] = ["FieldForge", "StudioForge"];
+
+export function SystemsGallery() {
+  const [line, setLine] = useState<LineFilter>("ALL");
+  const [cat, setCat] = useState<CatFilter>("ALL");
+  const [openId, setOpenId] = useState<string | null>(null);
+
+  // Which categories actually exist for the active line (so we never show an
+  // empty filter chip).
+  const availableCats = useMemo(() => {
+    const pool =
+      line === "ALL"
+        ? SYSTEM_IMAGES
+        : SYSTEM_IMAGES.filter((s) => s.line === line);
+    const present = new Set(pool.map((s) => s.category));
+    return CATEGORY_ORDER.filter((c) => present.has(c));
+  }, [line]);
+
+  // If the selected category isn't valid for the active line, treat it as ALL
+  // during render (no effect / no setState-in-effect cascade).
+  const effectiveCat: CatFilter =
+    cat !== "ALL" && !availableCats.includes(cat) ? "ALL" : cat;
+
+  const filtered = useMemo(() => {
+    return SYSTEM_IMAGES.filter(
+      (s) =>
+        (line === "ALL" || s.line === line) &&
+        (effectiveCat === "ALL" || s.category === effectiveCat)
+    );
+  }, [line, effectiveCat]);
+
+  const openIndex = useMemo(
+    () => (openId === null ? -1 : filtered.findIndex((s) => s.id === openId)),
+    [openId, filtered]
+  );
+  const active = openIndex >= 0 ? filtered[openIndex] : null;
+
+  // Lightbox: scroll lock + keyboard nav.
+  useEffect(() => {
+    if (openId === null) return;
+    document.body.style.overflow = "hidden";
+    const onKey = (e: KeyboardEvent) => {
+      if (e.key === "Escape") setOpenId(null);
+      if (e.key === "ArrowRight")
+        setOpenId((id) => {
+          const i = filtered.findIndex((s) => s.id === id);
+          return i < 0 ? id : filtered[(i + 1) % filtered.length].id;
+        });
+      if (e.key === "ArrowLeft")
+        setOpenId((id) => {
+          const i = filtered.findIndex((s) => s.id === id);
+          return i < 0
+            ? id
+            : filtered[(i - 1 + filtered.length) % filtered.length].id;
+        });
+    };
+    window.addEventListener("keydown", onKey);
+    return () => {
+      document.body.style.overflow = "";
+      window.removeEventListener("keydown", onKey);
+    };
+  }, [openId, filtered]);
+
+  const step = useCallback(
+    (dir: 1 | -1) => {
+      setOpenId((id) => {
+        const i = filtered.findIndex((s) => s.id === id);
+        if (i < 0) return id;
+        return filtered[(i + dir + filtered.length) % filtered.length].id;
+      });
+    },
+    [filtered]
+  );
+
+  return (
+    <div>
+      {/* Controls */}
+      <div className="mb-8 flex flex-col gap-4">
+        {/* Line toggle */}
+        <div className="flex flex-wrap items-center gap-2">
+          <span className="mr-1 text-[11px] font-semibold uppercase tracking-[1.5px] text-[#64748B]">
+            Product line
+          </span>
+          <Chip active={line === "ALL"} onClick={() => setLine("ALL")}>
+            All lines
+          </Chip>
+          {LINES.map((l) => (
+            <Chip key={l} active={line === l} onClick={() => setLine(l)}>
+              {LINE_META[l].label}
+            </Chip>
+          ))}
+        </div>
+
+        {/* Category filter */}
+        <div className="flex flex-wrap items-center gap-2">
+          <span className="mr-1 text-[11px] font-semibold uppercase tracking-[1.5px] text-[#64748B]">
+            Surface
+          </span>
+          <Chip active={effectiveCat === "ALL"} onClick={() => setCat("ALL")}>
+            All surfaces
+          </Chip>
+          {availableCats.map((c) => (
+            <Chip
+              key={c}
+              active={effectiveCat === c}
+              onClick={() => setCat(c)}
+            >
+              {CATEGORY_META[c].label}
+            </Chip>
+          ))}
+        </div>
+
+        {/* Active line description + count */}
+        <p className="text-[15px] leading-relaxed text-[#475569]">
+          {line === "ALL" ? (
+            <>
+              Showing <strong>{filtered.length}</strong> systems across both
+              product lines.
+            </>
+          ) : (
+            <>
+              <strong>{LINE_META[line].label}</strong> —{" "}
+              {LINE_META[line].blurb} Showing{" "}
+              <strong>{filtered.length}</strong>.
+            </>
+          )}
+        </p>
+      </div>
+
+      {/* Masonry-style responsive grid, Ken Burns per tile */}
+      <div className="grid grid-cols-2 gap-3 sm:grid-cols-3 sm:gap-4 lg:grid-cols-4">
+        {filtered.map((s, i) => (
+          <GalleryTile
+            key={s.id}
+            image={s}
+            motion={i % 4}
+            onClick={() => setOpenId(s.id)}
+          />
+        ))}
+      </div>
+
+      {filtered.length === 0 && (
+        <div className="rounded-2xl border border-dashed border-[#E2E8F0] p-12 text-center text-[#64748B]">
+          No systems match that filter.
+        </div>
+      )}
+
+      {/* LIGHTBOX */}
+      {active && (
+        <div
+          className="fixed inset-0 z-[95] flex items-center justify-center p-3 sm:p-6"
+          role="dialog"
+          aria-modal="true"
+          aria-label={CATEGORY_META[active.category].label}
+        >
+          <div
+            className="absolute inset-0 bg-[#0A2540]/80 backdrop-blur-sm animate-backdrop-in"
+            onClick={() => setOpenId(null)}
+          />
+
+          <div className="relative flex max-h-[calc(100dvh-1.5rem)] w-full max-w-6xl flex-col overflow-hidden rounded-3xl bg-white shadow-2xl animate-dialog-in sm:max-h-[calc(100dvh-3rem)]">
+            <button
+              onClick={() => setOpenId(null)}
+              aria-label="Close"
+              className="absolute right-4 top-4 z-20 flex h-10 w-10 items-center justify-center rounded-full bg-white/90 text-[#0A2540] shadow-md backdrop-blur transition hover:bg-white"
+            >
+              <X className="h-5 w-5" />
+            </button>
+            <button
+              onClick={() => step(-1)}
+              aria-label="Previous"
+              className="absolute left-3 top-1/2 z-20 hidden h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full bg-white/85 text-[#0A2540] shadow-md backdrop-blur transition hover:bg-white sm:flex"
+            >
+              <ChevronLeft className="h-5 w-5" />
+            </button>
+            <button
+              onClick={() => step(1)}
+              aria-label="Next"
+              className="absolute right-3 top-1/2 z-20 hidden h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full bg-white/85 text-[#0A2540] shadow-md backdrop-blur transition hover:bg-white sm:flex"
+            >
+              <ChevronRight className="h-5 w-5" />
+            </button>
+
+            <div className="grid flex-1 grid-cols-1 overflow-y-auto lg:grid-cols-[1.2fr_1fr]">
+              <div className="relative flex items-center justify-center bg-[#0A2540] p-4 lg:p-6">
+                <Image
+                  src={active.src}
+                  alt={`PaintForge ${active.line} — ${
+                    CATEGORY_META[active.category].label
+                  }`}
+                  width={784}
+                  height={1168}
+                  priority
+                  sizes="(max-width: 1024px) 90vw, 680px"
+                  className="h-auto max-h-[46vh] w-auto rounded-xl object-contain shadow-lg lg:max-h-[80vh]"
+                />
+                <span className="absolute left-6 top-6 inline-flex items-center gap-1.5 rounded-full bg-[#0A2540]/85 px-3 py-1 text-[11px] font-semibold uppercase tracking-[1.5px] text-white backdrop-blur">
+                  <span className="h-1.5 w-1.5 rounded-full bg-[#FF6B35]" />
+                  {active.line}
+                </span>
+              </div>
+
+              <div className="flex flex-col gap-5 p-6 sm:p-8">
+                <div>
+                  <div className="kicker mb-2">
+                    {active.line.toUpperCase()} ·{" "}
+                    {String(openIndex + 1).padStart(2, "0")}/
+                    {String(filtered.length).padStart(2, "0")}
+                  </div>
+                  <h3 className="text-2xl font-semibold tracking-tight text-[#0A2540] sm:text-3xl">
+                    {CATEGORY_META[active.category].label}
+                  </h3>
+                  <p className="mt-3 text-[15px] leading-relaxed text-[#475569]">
+                    {active.caption}
+                  </p>
+                  <p className="mt-2 text-sm leading-relaxed text-[#64748B]">
+                    {CATEGORY_META[active.category].blurb}
+                  </p>
+                </div>
+
+                <div className="rounded-xl border border-[#E2E8F0] bg-[#F8FAFC] p-4">
+                  <div className="mb-1 text-[11px] font-semibold uppercase tracking-[1.5px] text-[#64748B]">
+                    {LINE_META[active.line].tagline}
+                  </div>
+                  <p className="text-sm leading-relaxed text-[#475569]">
+                    {LINE_META[active.line].blurb}
+                  </p>
+                </div>
+
+                <p className="mt-auto text-xs leading-relaxed text-[#94A3B8]">
+                  Concept and pilot-development renders. Specifications and
+                  behaviors shown are engineering targets, not measured field
+                  results.
+                </p>
+              </div>
+            </div>
+          </div>
+        </div>
+      )}
+    </div>
+  );
+}
+
+function Chip({
+  active,
+  onClick,
+  children,
+}: {
+  active: boolean;
+  onClick: () => void;
+  children: React.ReactNode;
+}) {
+  return (
+    <button
+      type="button"
+      onClick={onClick}
+      className={
+        "rounded-full border px-4 py-1.5 text-sm font-medium transition " +
+        (active
+          ? "border-[#FF6B35] bg-[#FF6B35] text-white shadow-sm"
+          : "border-[#E2E8F0] bg-white text-[#475569] hover:border-[#CBD5E1] hover:-translate-y-0.5")
+      }
+    >
+      {children}
+    </button>
+  );
+}
+
+function GalleryTile({
+  image,
+  motion,
+  onClick,
+}: {
+  image: SystemImage;
+  motion: number;
+  onClick: () => void;
+}) {
+  return (
+    <button
+      type="button"
+      onClick={onClick}
+      className="card group relative aspect-[3/4] w-full overflow-hidden p-0 text-left"
+      aria-label={`Open ${CATEGORY_META[image.category].label}`}
+    >
+      <div className="absolute inset-0 overflow-hidden bg-[#0A2540]">
+        <Image
+          src={image.src}
+          alt={`PaintForge ${image.line} — ${
+            CATEGORY_META[image.category].label
+          }`}
+          fill
+          sizes="(max-width: 640px) 50vw, (max-width: 1024px) 33vw, 25vw"
+          className={`kb kb-${motion} object-cover object-top`}
+          style={{
+            animationIterationCount: "infinite",
+            animationDirection: "alternate",
+            animationDuration: "14s",
+          }}
+        />
+      </div>
+
+      {/* Legibility gradient */}
+      <div className="absolute inset-0 bg-gradient-to-t from-[#0A2540]/85 via-[#0A2540]/10 to-transparent" />
+
+      {/* Line badge */}
+      <span className="absolute left-2.5 top-2.5 rounded-full bg-[#0A2540]/80 px-2.5 py-0.5 text-[10px] font-semibold uppercase tracking-[1px] text-white backdrop-blur">
+        {image.line}
+      </span>
+
+      {/* Caption */}
+      <div className="absolute inset-x-0 bottom-0 p-3">
+        <div className="mb-0.5 text-[10px] font-semibold uppercase tracking-[1.5px] text-[#FF8C5A]">
+          {CATEGORY_META[image.category].label}
+        </div>
+        <p className="text-[12px] font-medium leading-snug text-white line-clamp-2">
+          {image.caption}
+        </p>
+      </div>
+    </button>
+  );
+}
