+import Link from "next/link";
+import { ArrowRight } from "lucide-react";
+import { SystemsGallery } from "@/components/SystemsGallery";
+import { ApplyCTA } from "@/components/ApplyModal";
+import { SYSTEM_IMAGES, LINE_META } from "@/lib/systemsCatalog";
+
+export const metadata = {
+  title: "Systems Gallery | PaintForge — Autonomous Painting Robots",
+  description:
+    "The full PaintForge systems library: 80 renders across two product lines — FieldForge autonomous field units and StudioForge commissioning units — working walls, ceilings, corridors, stairwells, and detail.",
+  alternates: { canonical: "/gallery" },
+};
+
+export default function GalleryPage() {
+  const total = SYSTEM_IMAGES.length;
+  const fieldforge = SYSTEM_IMAGES.filter((s) => s.line === "FieldForge").length;
+  const studioforge = total - fieldforge;
+
+  return (
+    <div>
+      {/* Hero */}
+      <section className="bg-[#0A2540] py-16 text-white">
+        <div className="max-w-7xl mx-auto px-6">
+          <div className="section-header section-header--dark">
+            <div className="kicker mb-3">SYSTEMS GALLERY</div>
+            <h1 className="section-heading text-white">
+              Every system, every surface.
+            </h1>
+            <p className="mt-4 max-w-3xl text-lg text-white/70">
+              The complete PaintForge systems library — {total} renders across
+              two product lines. Filter by line or surface, and open any system
+              for its category, caption, and line context.
+            </p>
+          </div>
+
+          {/* Line summary */}
+          <div className="mt-10 grid gap-4 sm:grid-cols-2">
+            {(["FieldForge", "StudioForge"] as const).map((l) => (
+              <div
+                key={l}
+                className="rounded-2xl border border-white/10 bg-white/5 p-6"
+              >
+                <div className="flex items-baseline justify-between">
+                  <h2 className="text-xl font-semibold tracking-tight">
+                    {LINE_META[l].label}
+                  </h2>
+                  <span className="font-mono text-sm text-[#FF8C5A]">
+                    {l === "FieldForge" ? fieldforge : studioforge} views
+                  </span>
+                </div>
+                <div className="mt-1 text-[11px] font-semibold uppercase tracking-[1.5px] text-white/50">
+                  {LINE_META[l].tagline}
+                </div>
+                <p className="mt-3 text-sm leading-relaxed text-white/70">
+                  {LINE_META[l].blurb}
+                </p>
+              </div>
+            ))}
+          </div>
+        </div>
+      </section>
+
+      {/* Gallery grid */}
+      <section className="max-w-7xl mx-auto px-6 py-16">
+        <SystemsGallery />
+      </section>
+
+      {/* CTA */}
+      <section className="bg-[#F8FAFC] border-t border-[#E2E8F0] py-16">
+        <div className="max-w-4xl mx-auto px-6 text-center">
+          <div className="kicker mb-3">2026 PILOT PROGRAM</div>
+          <h2 className="section-heading mx-auto">
+            Want to see one of these on your site?
+          </h2>
+          <p className="mx-auto mt-4 max-w-2xl text-lg text-[#475569]">
+            We are recruiting a small GTA design-partner cohort for 2026 pilot
+            deployments. If painter shortages are costing you schedule or
+            margin, let&apos;s model your ROI together.
+          </p>
+          <div className="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
+            <ApplyCTA />
+            <Link
+              href="/#autonomous-systems"
+              className="btn-secondary inline-flex items-center gap-2 px-8 py-4 text-lg"
+            >
+              Back to the showcase
+              <ArrowRight className="h-5 w-5" />
+            </Link>
+          </div>
+        </div>
+      </section>
+    </div>
+  );
+}
