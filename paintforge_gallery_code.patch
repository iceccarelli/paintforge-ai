+// AUTO-GENERATED catalog of the PaintForge systems image library.
+// 80 unique, deduplicated renders across two product lines and
+// eight functional categories. Edit captions here in one place.
+
+export type SystemLine = "FieldForge" | "StudioForge";
+export type SystemCategory =
+  | "WALL" | "CEIL" | "STAIR" | "CORRIDOR"
+  | "ROOM" | "DETAIL" | "TRANSIT" | "DOCK";
+
+export type SystemImage = {
+  id: string;
+  src: string;
+  line: SystemLine;
+  category: SystemCategory;
+  caption: string;
+};
+
+export const CATEGORY_META: Record<
+  SystemCategory,
+  { label: string; blurb: string }
+> = {
+  WALL: { label: "Wall Coating", blurb: "Full-height vertical surfaces sprayed to a uniform film." },
+  CEIL: { label: "Ceiling & Overhead", blurb: "Overhead passes with the arm elevated into the ceiling plane." },
+  STAIR: { label: "Stairwells", blurb: "Tall shaft walls reached from a level landing, no scaffold." },
+  CORRIDOR: { label: "Corridors & Long Runs", blurb: "Indexed segments down long, repeatable wall runs." },
+  ROOM: { label: "Room-Scale", blurb: "Whole-room sequencing from a single site scan." },
+  DETAIL: { label: "Spray-Head & Detail", blurb: "Servo-gun, nozzle, and pressure-control close-ups." },
+  TRANSIT: { label: "Autonomous Transit", blurb: "Self-driving between zones, thresholds, and doorways." },
+  DOCK: { label: "Dock & Standby", blurb: "Idle, self-leveled, or charging between tasks." },
+};
+
+export const LINE_META: Record<
+  SystemLine,
+  { label: string; tagline: string; blurb: string }
+> = {
+  FieldForge: {
+    label: "FieldForge",
+    tagline: "Autonomous field unit",
+    blurb:
+      "Our documented field line — captured working independently on real job-site walls, ceilings, corridors, and stairwells.",
+  },
+  StudioForge: {
+    label: "StudioForge",
+    tagline: "Commissioning & in-situ unit",
+    blurb:
+      "Our commissioning line — captured across staged and live finishing environments, from pressure-rig detail to full in-situ passes.",
+  },
+};
+
